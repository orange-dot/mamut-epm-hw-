	(text "Rail-aware matched-pair/tempco expo capture for `P1`.\n`Q60` and `Q61` form the thermally-coupled NPN control pair, `R60` + `RV60` now own the real scale path,\n`RV61` owns offset placement from `REFERENCE`, and `Q62` stays only as the sourced output helper into `EXPO_OUT`."
		(exclude_from_sim no)
		(at 22.86 124.46 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "0e200001-0000-4000-8000-000000000007")
	)
