	(text "Bench-fed analog support sheet.\nRight now this does not own the final PSU architecture.\nIt owns rail vocabulary, light local decoupling, and a low-impedance `REFERENCE` node for the current threshold studies."
		(exclude_from_sim no)
		(at 38.1 109.22 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "55555555-5555-5555-8555-000000000005")
	)
	(text "Nominal `REFERENCE` target is about 1.0 V from the `+12 V` rail.\nThe divider is intentionally low-impedance so the current `R10 = 100k` threshold load does not bend it badly.\nTrimmed or buffered reference work can come later."
		(exclude_from_sim no)
		(at 38.1 125.73 0)
		(effects
			(font
				(size 1.016 1.016)
			)
			(justify left bottom)
		)
		(uuid "55555555-5555-5555-8555-000000000006")
	)
